# === Required ===

# Google OAuth (https://console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
REDIRECT_URI=http://localhost:3001/auth/google/callback

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=replace_with_random_string

# PostgreSQL connection
DATABASE_URL=postgresql://localhost:5432/email_ai

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173
PORT=3001

# === Optional: Outlook OAuth ===
# (https://portal.azure.com > App Registrations)
# OUTLOOK_CLIENT_ID=your_outlook_client_id
# OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
# OUTLOOK_REDIRECT_URI=http://localhost:3001/auth/outlook/callback
